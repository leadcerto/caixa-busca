APP_NAME="Imóveis da Caixa"
# Em produção: APP_ENV=production, APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u123456789_caixa
DB_USERNAME=u123456789_admin
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CONFIGURAÇÕES DE LEAD E INTEGRAÇÃO
CRM_WEBHOOK_URL=https://exemplo.com/webhook
CRM_WEBHOOK_TOKEN=sb_webhook_secret_token
WHATSAPP_CENTRAL=5511999999999

# IA — Geração de conteúdo para bairros (Anthropic Claude)
ANTHROPIC_API_KEY=

# ADMINISTRADOR PADRÃO (usado pelo db:seed — não reutilize em produção após o primeiro seed)
ADMIN_EMAIL=admin@imoveisdacaixa.com.br
ADMIN_PASSWORD=

# IMOBILIÁRIA DEMO (opcional — seed cria uma parceira de exemplo para testes)
IMOBILIARIA_DEMO_EMAIL=parceiro@imoveisdacaixa.com.br
IMOBILIARIA_DEMO_NOME=Imobiliária Parceira Padrão
IMOBILIARIA_DEMO_SENHA=
IMOBILIARIA_DEMO_WHATSAPP=5521999999999
IMOBILIARIA_DEMO_CRECI=CRECI-00000-J

# ROTA DE DIAGNÓSTICO — /verificar-erro-sistema?token=<valor>
# Deixe vazio para desativar a rota em produção.
DIAGNOSTICO_TOKEN=

# FILA — Em produção, configure o Supervisor para manter queue:work rodando:
# [program:caixa-worker]
# command=php /var/www/artisan queue:work --sleep=3 --tries=3 --max-time=3600
# autostart=true
# autorestart=true
# redirect_stderr=true
# stdout_logfile=/var/log/supervisor/caixa-worker.log
