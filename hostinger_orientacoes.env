#
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://venda.imoveisdacaixa.com.br
# QUEUE_CONNECTION=database
# SESSION_SECURE_COOKIE=true
#
# Conferir via SSH:
#
# cd /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
#
# composer install --no-dev --optimize-autoloader
# php artisan optimize:clear
# php artisan migrate --force
# php artisan storage:link
# chmod -R 775 storage bootstrap/cache
# php artisan config:cache
# php artisan route:cache
# php artisan view:cache
#
# Conferir no hPanel:
#
# 1. PHP 8.3.30 ativo ou versão compatível com o projeto.
# 2. Subdomínio apontando para public_html/venda.
# 3. Cron do scheduler configurado.
# 4. Cron da queue configurado, se o projeto usar filas.
# 5. Logs acessíveis em Websites → Error logs.
#
# Testar no navegador:
#
# https://venda.imoveisdacaixa.com.br

# ==============================================================================
