# ==============================================================================
# 🏠 HOSTINGER + LARAVEL — ORIENTAÇÕES DO PROJETO
# ==============================================================================
#
# 📌 Arquivo: hostinger_orientacoes.env
#
# Este arquivo serve como guia para configurar e manter o Laravel na Hostinger.
# Ele foi feito para ser lido até por pessoas sem conhecimento técnico avançado.
#
# Projeto:
# venda.imoveisdacaixa.com.br
#
# Domínio principal:
# imoveisdacaixa.com.br
#
# Subdomínio:
# venda.imoveisdacaixa.com.br
#
# Hospedagem:
# Hostinger — hPanel
#
# ==============================================================================
# 📁 ESTRUTURA RECOMENDADA DE PASTAS
# ==============================================================================
#
# ✅ Pasta principal do Laravel:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
#
# ✅ Pasta pública do subdomínio:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda
#
# ⚠️ Importante:
# O Laravel inteiro NÃO deve ficar exposto dentro de public_html.
# O ideal é deixar o projeto completo em "laravel-venda"
# e publicar apenas a pasta "public" em "public_html/venda".
#
# O arquivo "artisan" deve ficar em:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/artisan
#
# E NÃO em:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda/artisan
#
# A não ser que o projeto Laravel inteiro tenha sido colocado dentro de public_html,
# o que não é o mais recomendado.
#
# ==============================================================================
# 🌐 URL DO SISTEMA
# ==============================================================================

APP_URL=https://venda.imoveisdacaixa.com.br

# ==============================================================================
# 🧩 CONFIGURAÇÃO BASE DO LARAVEL
# ==============================================================================
#
# Use estas configurações no arquivo .env real do Laravel.
#
# Caminho do .env real:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/.env
#
# ⚠️ APP_KEY:
# A chave APP_KEY deve ser gerada pelo comando:
#
# php artisan key:generate
#
# Depois disso, o Laravel preencherá automaticamente o valor.

APP_NAME="Venda Imóveis da Caixa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# ==============================================================================
# 📝 LOGS DO LARAVEL
# ==============================================================================
#
# Os logs internos do Laravel ficam em:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/storage/logs/laravel.log
#
# Também é possível consultar logs da hospedagem pelo hPanel:
#
# Websites → Error logs
#
# Em produção, recomenda-se LOG_LEVEL=error para registrar apenas erros importantes.

LOG_CHANNEL=stack
LOG_LEVEL=error

# ==============================================================================
# 🗄️ BANCO DE DADOS MYSQL
# ==============================================================================
#
# Preencha os dados reais do banco criado na Hostinger.
#
# Normalmente, na Hostinger:
# DB_HOST=localhost
# DB_PORT=3306
#
# ⚠️ Substitua os valores abaixo:
#
# nome_do_banco
# nome_do_usuario
# sua_senha_do_banco

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nome_do_banco
DB_USERNAME=nome_do_usuario
DB_PASSWORD=sua_senha_do_banco

# ==============================================================================
# 🔐 SESSÕES DO LARAVEL
# ==============================================================================
#
# SESSION_DRIVER=file:
# Salva sessões em arquivos dentro do próprio Laravel.
# É uma opção simples e segura para hospedagem compartilhada.
#
# SESSION_SECURE_COOKIE=true:
# Obriga cookies de sessão a usarem HTTPS.
# Use true porque o site deve funcionar com SSL.

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# ==============================================================================
# ⚡ CACHE
# ==============================================================================
#
# CACHE_STORE=file:
# Usa cache em arquivos.
# É adequado para hospedagem compartilhada.

CACHE_STORE=file

# ==============================================================================
# 📬 FILAS / QUEUES
# ==============================================================================
#
# Em hospedagem compartilhada, NÃO é recomendado manter queue:work rodando
# como processo infinito.
#
# O mais seguro é usar fila com banco de dados e processar via Cron Job
# em execuções curtas.
#
# Configuração recomendada:

QUEUE_CONNECTION=database

# Para criar a tabela de jobs, rode via SSH:
#
# cd /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
# php artisan queue:table
# php artisan migrate --force
#
# Depois configure o Cron Job no hPanel:
#
# * * * * * /usr/bin/php /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/artisan queue:work database --stop-when-empty --tries=3 --timeout=60 >> /dev/null 2>&1
#
# Explicação:
#
# --stop-when-empty
# Processa os jobs existentes e encerra.
#
# --tries=3
# Tenta executar cada job até 3 vezes antes de marcar como falho.
#
# --timeout=60
# Cada job pode rodar por até 60 segundos.
#
# Isso evita deixar um processo infinito rodando na hospedagem compartilhada.

# ==============================================================================
# 📁 ARQUIVOS / STORAGE
# ==============================================================================
#
# FILESYSTEM_DISK=public:
# Usado para arquivos públicos, uploads, imagens etc.
#
# O link simbólico do storage deve apontar:
#
# De:
# /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda/storage
#
# Para:
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/storage/app/public
#
# Comando padrão:
#
# php artisan storage:link
#
# Se não funcionar, criar manualmente:
#
# ln -s /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/storage/app/public /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda/storage

FILESYSTEM_DISK=public

# ==============================================================================
# 📧 E-MAIL / SMTP
# ==============================================================================
#
# Ainda não temos os dados SMTP confirmados para o domínio imoveisdacaixa.com.br.
#
# O ideal é usar o provedor de e-mail do próprio domínio.
#
# Quando tiver os dados, preencher:
#
# MAIL_HOST
# MAIL_PORT
# MAIL_USERNAME
# MAIL_PASSWORD
# MAIL_ENCRYPTION
# MAIL_FROM_ADDRESS
#
# Exemplo comum:
#
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
#
# ⚠️ Atenção:
# Não deixe senha real em arquivos compartilhados por WhatsApp, e-mail ou prints.

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# 🧠 PHP NA HOSTINGER
# ==============================================================================
#
# Informações confirmadas:
#
# PHP ativo no subdomínio:
# PHP 8.3.30
#
# É possível alterar a versão do PHP pelo hPanel.
#
# Diretivas PHP ajustáveis:
#
# upload_max_filesize
# post_max_size
# max_input_vars
# max_execution_time
#
# Valores atuais:
#
# upload_max_filesize = 2048M
# post_max_size       = 2048M
# max_input_vars      = 5000
# max_execution_time  = 360
# memory_limit        = 1536M
#
# Isso é suficiente para a maioria dos projetos Laravel.

# ==============================================================================
# 🧱 EXTENSÕES PHP CONFIRMADAS
# ==============================================================================
#
# Extensões já confirmadas:
#
# openssl
# pdo
# mbstring
# ctype
# json
# bcmath
# fileinfo
# curl
# intl
#
# Para verificar extensões via SSH:
#
# php -m
#
# Para procurar extensões específicas:
#
# php -m | grep -E "openssl|pdo|mbstring|tokenizer|xml|ctype|json|bcmath|fileinfo|curl|zip|intl"

# ==============================================================================
# 🧑‍💻 SSH E COMPOSER
# ==============================================================================
#
# SSH está disponível no plano.
#
# Composer pode ser usado via SSH.
#
# Para verificar a versão do Composer:
#
# composer -V
#
# Caminho correto para rodar comandos:
#
# cd /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
#
# Instalar dependências PHP:
#
# composer install --no-dev --optimize-autoloader
#
# Se der erro de memória:
#
# COMPOSER_MEMORY_LIMIT=-1 composer install --no-dev --optimize-autoloader

# ==============================================================================
# 🚀 COMANDOS DE DEPLOY RECOMENDADOS
# ==============================================================================
#
# Rodar estes comandos via SSH dentro da pasta do projeto:
#
# cd /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
#
# 1. Instalar dependências:
#
# composer install --no-dev --optimize-autoloader
#
# 2. Limpar caches antigos:
#
# php artisan optimize:clear
#
# 3. Gerar APP_KEY se ainda não existir:
#
# php artisan key:generate
#
# 4. Rodar migrations:
#
# php artisan migrate --force
#
# 5. Criar link do storage:
#
# php artisan storage:link
#
# 6. Ajustar permissões:
#
# chmod -R 775 storage bootstrap/cache
#
# 7. Otimizar Laravel para produção:
#
# php artisan config:cache
# php artisan route:cache
# php artisan view:cache
# php artisan event:cache

# ==============================================================================
# ⏰ CRON JOBS NO HPANEL
# ==============================================================================
#
# Cron Jobs devem ser configurados no hPanel:
#
# hPanel → Cron Jobs
#
# PHP no cron:
#
# /usr/bin/php
#
# ------------------------------------------------------------------------------
# ✅ CRON DO SCHEDULER DO LARAVEL
# ------------------------------------------------------------------------------
#
# Este cron roda o agendador do Laravel a cada minuto.
#
# Use exatamente:
#
# * * * * * /usr/bin/php /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/artisan schedule:run >> /dev/null 2>&1
#
# Explicação simples:
#
# * * * * *
# Significa "rodar a cada minuto".
#
# schedule:run
# Faz o Laravel verificar se existe alguma tarefa agendada para executar.
#
# >> /dev/null 2>&1
# Oculta a saída do comando para evitar acúmulo de logs desnecessários.
#
# ------------------------------------------------------------------------------
# ✅ CRON DA FILA / QUEUE
# ------------------------------------------------------------------------------
#
# Recomendado para hospedagem compartilhada:
#
# * * * * * /usr/bin/php /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/artisan queue:work database --stop-when-empty --tries=3 --timeout=60 >> /dev/null 2>&1
#
# Esse comando processa a fila e encerra quando não houver mais jobs.
#
# ⚠️ Evitar:
#
# queue:work rodando para sempre
# queue:listen contínuo
#
# Esses modos são melhores para VPS, não para hospedagem compartilhada.

# ==============================================================================
# 🌐 URL REWRITE / ROTAS AMIGÁVEIS
# ==============================================================================
#
# A Hostinger suporta URL Rewrite / mod_rewrite para Laravel.
#
# É necessário usar o .htaccess padrão dentro da pasta public do Laravel.
#
# O webroot do subdomínio deve apontar para a pasta pública:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda
#
# Se as rotas do Laravel derem erro 404:
#
# 1. Verifique se o .htaccess existe em public_html/venda
# 2. Verifique se o conteúdo é o padrão do Laravel
# 3. Verifique se o subdomínio está apontando para a pasta correta

# ==============================================================================
# 🧰 NODE.JS / NPM / VITE
# ==============================================================================
#
# O hPanel não confirmou se Node.js/npm estão disponíveis.
#
# Para testar via SSH:
#
# cd /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda
#
# node -v
# npm -v
# which node
# which npm
#
# Se Node e npm existirem, pode rodar:
#
# npm install
# npm run build
#
# Se der erro de memória:
#
# NODE_OPTIONS=--max-old-space-size=1024 npm run build
#
# Se ainda falhar, faça o build no computador local e envie a pasta:
#
# public/build
#
# Para o servidor em:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/public_html/venda/build

# ==============================================================================
# 🧪 COMANDOS DE TESTE
# ==============================================================================
#
# Ver informações gerais do Laravel:
#
# php artisan about
#
# Limpar todos os caches:
#
# php artisan optimize:clear
#
# Ver últimas linhas do log do Laravel:
#
# tail -n 100 storage/logs/laravel.log
#
# Ver versão do PHP:
#
# php -v
#
# Ver versão do Composer:
#
# composer -V
#
# Ver extensões PHP:
#
# php -m

# ==============================================================================
# 🧯 SE DER ERRO 500
# ==============================================================================
#
# Verifique primeiro:
#
# 1. Log do Laravel:
#
# /home/u541302702/domains/imoveisdacaixa.com.br/laravel-venda/storage/logs/laravel.log
#
# Comando:
#
# tail -n 100 storage/logs/laravel.log
#
# 2. Logs no hPanel:
#
# Websites → Error logs
#
# 3. Permissões:
#
# chmod -R 775 storage bootstrap/cache
#
# 4. APP_KEY:
#
# php artisan key:generate
#
# 5. Cache antigo:
#
# php artisan optimize:clear
#
# 6. Banco de dados:
#
# Confira DB_DATABASE, DB_USERNAME e DB_PASSWORD no .env real.

# ==============================================================================
# 🔒 SEGURANÇA BÁSICA
# ==============================================================================
#
# Em produção, manter:
#
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true
#
# Nunca deixar:
#
# APP_DEBUG=true
#
# em site publicado, porque isso pode mostrar dados sensíveis em tela.
#
# Também não compartilhe:
#
# DB_PASSWORD
# MAIL_PASSWORD
# APP_KEY
#
# em prints, mensagens ou arquivos públicos.

# ==============================================================================
# 🧱 WAF / CDN / FIREWALL
# ==============================================================================
#
# No momento, não há WAF/CDN ativo para:
#
# venda.imoveisdacaixa.com.br
#
# Portanto, não há uma regra de WAF dessa camada bloqueando:
#
# POST
# uploads
# APIs
#
# Mesmo assim, o próprio servidor ou o Laravel podem bloquear requisições
# fora do padrão, dependendo de validações, tamanho do arquivo ou regras internas.

# ==============================================================================
# 💾 BACKUPS
# ==============================================================================
#
# A frequência exata de backup automático não foi confirmada.
#
# Recomendação:
#
# 1. Verificar no hPanel se o plano possui backup automático.
# 2. Antes de qualquer deploy importante, baixar backup dos arquivos.
# 3. Antes de migrations importantes, exportar backup do banco MySQL.
#
# Nunca rodar migrations destrutivas sem backup.

# ==============================================================================
